NODE_ENV=production
PORT=3000

# MySQL — di Railway, link dari MySQL service (jangan pakai localhost)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Wajib: string random panjang
JWT_SECRET="ganti-dengan-string-random-panjang"

# Sementara tanpa broker (Railway gratis): set false dan kosongkan MQTT_URL
MQTT_ENABLED=false
# MQTT_URL="mqtt://broker.example.com:1883"
