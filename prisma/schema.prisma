generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  devices   Device[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Device {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  name       String
  claimCode  String      @unique
  token      String      @unique
  claimed    Boolean     @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime    @default(now())
  telemetry  Telemetry[]

  @@index([tenantId])
}

model Telemetry {
  id       BigInt   @id @default(autoincrement())
  deviceId String
  device   Device   @relation(fields: [deviceId], references: [id])
  tenantId String
  ts       DateTime @default(now())
  data     Json

  @@index([deviceId, ts])
  @@index([tenantId, ts])
}