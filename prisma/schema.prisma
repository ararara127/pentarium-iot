generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  devices   Device[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Device {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  name       String
  claimCode  String      @unique
  token      String      @unique
  claimed    Boolean     @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime    @default(now())
  telemetry  Telemetry[]
  alertRules AlertRule[]
  alerts     Alert[]

  @@index([tenantId])
}

model Telemetry {
  id       BigInt   @id @default(autoincrement())
  deviceId String
  device   Device   @relation(fields: [deviceId], references: [id])
  tenantId String
  ts       DateTime @default(now())
  data     Json

  @@index([deviceId, ts])
  @@index([tenantId, ts])
}

model AlertRule {
  id        String   @id @default(cuid())
  tenantId  String
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id])
  metric    String   // contoh: "suhu"
  operator  String   // ">" atau "<"
  threshold Float
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  alerts    Alert[]

  @@index([deviceId])
  @@index([tenantId])
}

model Alert {
  id        String    @id @default(cuid())
  tenantId  String
  deviceId  String
  device    Device    @relation(fields: [deviceId], references: [id])
  ruleId    String
  rule      AlertRule @relation(fields: [ruleId], references: [id])
  message   String
  value     Float
  createdAt DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([deviceId])
}